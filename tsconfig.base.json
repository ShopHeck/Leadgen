{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@closerflow/db": ["packages/db/src/index.ts"],
      "@closerflow/db/*": ["packages/db/src/*"],
      "@closerflow/types": ["packages/types/src/index.ts"],
      "@closerflow/types/*": ["packages/types/src/*"],
      "@closerflow/ui": ["packages/ui/src/index.ts"],
      "@closerflow/ui/*": ["packages/ui/src/*"]
    }
  }
}

